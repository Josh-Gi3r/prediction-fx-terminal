# ── FX Settlement provider ────────────────────────────────────────────────────
# Client-side settlement REST base (browser reads /fx/rate, /tokens, maker orders).
# Point this at your FX settlement provider (e.g. an orderbook CLOB or RFQ desk).
NEXT_PUBLIC_FX_PROVIDER_API_BASE=https://api.your-fx-provider.example.com/api/v1
# Server-side settlement REST base alias (API routes: /api/quotes, /api/swap, /api/vl/*).
# Reads NEXT_PUBLIC_FX_PROVIDER_API_BASE first, then FX_PROVIDER_API, then the default above.
FX_PROVIDER_API=https://api.your-fx-provider.example.com/api/v1
# Server-only: API key for in-app vault deposit builder (/api/fx-deposit) and
# order-status polling (/api/order-status). Without these, deposit falls back to
# a "fund via external settlement app" link and order-status polling requires no auth.
# FX_PROVIDER_API_KEY=
# FX_PROVIDER_API_SECRET=

# ── Chain ────────────────────────────────────────────────────────────────────
# Default is MAINNET (1) — FX provider live + LiFi/Kyber/CoW comparison only exist there.
# Set 11155111 explicitly for a Sepolia testnet build.
NEXT_PUBLIC_FX_PROVIDER_CHAIN_ID=1

# ── RPC URLs ─────────────────────────────────────────────────────────────────
# Public node defaults — replace with paid RPCs for production.
NEXT_PUBLIC_RPC=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
NEXT_PUBLIC_BASE_RPC=https://base-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_RPC=https://arbitrum-one-rpc.publicnode.com
# Server-only: used by /api/account/login for EIP-1271 smart-wallet verification.
# Falls back to a public LlamaRPC node if unset; set a paid RPC in production.
ETH_RPC_URL=https://eth.llamarpc.com

# ── DEX routers ──────────────────────────────────────────────────────────────
# LiFi integrator ID — used by /api/bridge-quote and quote attribution.
# Register your own at https://li.fi/sdk
NEXT_PUBLIC_LIFI_INTEGRATOR=your-app-name
# Server-only: LiFi API key — optional but recommended in production to avoid
# rate limits on /api/bridge-quote (LiFi throttles keyless calls).
# LIFI_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Leave empty to run without Privy: the app falls back to a plain injected()
# EOA connector (MetaMask/Rabby) so everything still works pre-Privy.
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-only app secret for the /api/wallet/transfer route (user-pays gas sends).
# Required when NEXT_PUBLIC_FEATURE_GASLESS_SEND=true. Never set as NEXT_PUBLIC_.
# PRIVY_APP_SECRET=

# ── Session (REQUIRED) ────────────────────────────────────────────────────────
# HMAC secret for HS256 session JWTs. Must be set — server throws at login if absent.
# Generate: openssl rand -hex 32
SESSION_JWT_SECRET=

# ── Database (REQUIRED for account/VL/activity features) ─────────────────────
# postgres://user:password@host:5432/dbname?sslmode=require
# Routes that need the DB return 500 with a clear error if this is unset.
DATABASE_URL=

# ── Telegram Mini App ────────────────────────────────────────────────────────
# Server-only bot token from BotFather — used by /api/telegram/auth to HMAC-verify
# initData. Without this, Telegram identity verification returns 500 (safe-fail).
# The app still works (falls back to email login) if this is not set.
# NEVER set this as NEXT_PUBLIC_ — it must stay server-side only.
# TELEGRAM_BOT_TOKEN=

# ── Site ─────────────────────────────────────────────────────────────────────
# Set to the deployed domain. Used by the Privy callback and the PM signing origin.
NEXT_PUBLIC_SITE_URL=https://your-app.example.com
# Display name shown in metadata, auth UX copy, and JWT issuer/audience.
APP_NAME=PredFX Terminal
# Client-readable display name (header, wallet prompts, share copy).
NEXT_PUBLIC_APP_NAME=PredFX Terminal
# localStorage / IndexedDB key namespace. Bump to invalidate all client cache
# (preferences, activity log, peer intents) without touching the DB.
NEXT_PUBLIC_STORAGE_NS=predfx

# ── Peer (zkP2P) fiat ramp ───────────────────────────────────────────────────
# OFF by default. true = show /cash (PRODUCTION zkp2p endpoints, Base mainnet
# escrow, onramped USDC bridges to Ethereum). Money only moves via user-signed txs.
NEXT_PUBLIC_FEATURE_PEER=false
# staging = api-staging.zkp2p.xyz (still Base 8453 — Peer has no testnet)
# NEXT_PUBLIC_PEER_ENV=staging
# App referrer fee on onramp quotes (revenue hook); unset = no fee taken.
# NEXT_PUBLIC_PEER_REFERRER_ADDRESS=0xYOUR_FEE_RECIPIENT_ADDRESS
# NEXT_PUBLIC_PEER_REFERRER_FEE_BPS=25

# ── Polymarket prediction market ─────────────────────────────────────────────
# Server-side only. Builder code is public (on-chain in orders); key/secret/
# passphrase are server-side only and required for /api/pm/builder-sign to work.
# Obtain credentials from https://docs.polymarket.com/developers/api/order-signing
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# OFF by default. true = enable real order placement (EIP-712 domain, USDC approve,
# and settlement must be verified correct before flipping on in prod).
NEXT_PUBLIC_FEATURE_PM_BETTING=false

# ── Gasless Send (Privy user-pays gas) ───────────────────────────────────────
# OFF by default. Flip to true after enabling the "user pays gas" toggle in the
# Privy dashboard for Ethereum/USDC and Ethereum/USDT rows. Also requires
# PRIVY_APP_SECRET (server-only) to be set.
# When enabled, USDC/USDT rows in /portfolio get a Send button. Gas is deducted
# from the transferred token — no ETH needed in the user's wallet.
NEXT_PUBLIC_FEATURE_GASLESS_SEND=false

# ── Waitlist ──────────────────────────────────────────────────────────────────
# Optional: absolute path to an append-only NDJSON file for waitlist signups.
# Without it, entries are logged to stdout only (suitable for log capture).
# WAITLIST_LOG_PATH=/var/data/waitlist.ndjson

# ── Event content module ──────────────────────────────────────────────────────
# The bundled WC2026 event is a swappable example module under app/wc/ and
# components/events/wc2026/. Set false to hide the nav item and disable the route.
NEXT_PUBLIC_FEATURE_EVENT_MODULE=true

# ── FX Provider EIP-712 domain ────────────────────────────────────────────────
# The EIP-712 domain name used for signing swap intents. Must match the
# verifying contract's domain exactly — read from your provider's GET /config.
# Default is the reference implementation's value.
NEXT_PUBLIC_EIP712_DOMAIN_NAME=FX Provider
